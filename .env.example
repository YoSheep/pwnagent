# PentestPilot LLM provider keys
# 复制为 .env 后填写。`.env` 已被 .gitignore 忽略，不会提交到仓库。

# Anthropic 官方
ANTHROPIC_API_KEY=""

# MiniMax（Anthropic 兼容网关；中国区和国际区默认共用这个环境变量）
MINIMAX_API_KEY=""

# OpenAI 官方
OPENAI_API_KEY=""

# Google Gemini（OpenAI-compatible）
GEMINI_API_KEY=""

# Groq（OpenAI-compatible）
GROQ_API_KEY=""

# xAI / Grok（OpenAI-compatible）
XAI_API_KEY=""

# Together AI（OpenAI-compatible）
TOGETHER_API_KEY=""

# Fireworks AI（OpenAI-compatible）
FIREWORKS_API_KEY=""

# Mistral（OpenAI-compatible 风格接口）
MISTRAL_API_KEY=""

# 下面这些 provider 也已在 config.yaml 预留，按需填写并补充对应 model
DEEPSEEK_API_KEY=""
OPENROUTER_API_KEY=""
MOONSHOT_API_KEY=""
DASHSCOPE_API_KEY=""
ZHIPU_API_KEY=""
SILICONFLOW_API_KEY=""

# 可选：直接覆盖当前默认 provider
# PENTESTPILOT_LLM_PROVIDER="anthropic"
